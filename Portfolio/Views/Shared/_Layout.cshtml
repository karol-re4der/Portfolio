@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/carousel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Portfolio.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Fotokozak</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                @* Sections *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between mr-auto">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Portret">Portret</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Teatr">Teatr</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Reportaz">Reportaż</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Koncerty">Koncerty</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Sport">Sport</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Pupile">Pupile</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="User" asp-controller="Gallery" asp-action="Section" asp-route-section="Street">Street</a>
                        </li>
                    </ul>
                </div>

                @* Social Icons *@
                <div class="d-none d-sm-block">
                    <ul class="navbar-nav flex-grow-1">
                        <partial name="/Views/Shared/_SocialIcons.cshtml" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (SignInManager.IsSignedIn(User))
    {
        //offcanvas admin dashboard
        <partial name="/Views/Shared/_Dashboard.cshtml"></partial>

        //A button to enter dashboard
        <div class="position-fixed bottom-0 start-0 mb-3 ms-3 z-3">
            <button class="btn btn-primary border-black py-2 d-flex align-items-center" id="bd-dash" type="button" data-bs-toggle="offcanvas" data-bs-target="#dashboard-offcanvas">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-lines-fill" viewBox="0 0 16 16">
                    <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5 6s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zM11 3.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5m.5 2.5a.5.5 0 0 0 0 1h4a.5.5 0 0 0 0-1zm2 3a.5.5 0 0 0 0 1h2a.5.5 0 0 0 0-1zm0 3a.5.5 0 0 0 0 1h2a.5.5 0 0 0 0-1z" />
                </svg>
            </button>
        </div>
    }

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer text-muted">
        <div class="container">
            <div class="row">
                <div class="col text-start">
                    <span>Fotokozak 2025</span>
                </div>
                <div class="col text-end">
                    <a class="text-reset text-decoration-underline" href="#">Wróć do góry</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js" integrity="sha384-GNFwBvfVxBkLMJpYMOABq3c+d3KnQxudP/mGPkzpZSTYykLBNsZEnG2D9G/X/+7D" crossorigin="anonymous" async></script>
    <script src="https://cdn.tiny.cloud/1/688v3eg9dq8wujzjpodph7fi557sl4r1ubasxyc6h5cjsqhl/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: 'textarea#content-tiny',
            menubar: ''
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
