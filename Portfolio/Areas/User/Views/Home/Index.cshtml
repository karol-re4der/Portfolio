@using Portfolio.Models.Models.ViewModels
@model HomeViewModel

@{
    ViewData["Title"] = "Fotokozak";
}
<div class="container p-0 m-0 mw-100">
    <div id="myCarousel" class="carousel slide mb-0" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="0" class="" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="1" aria-label="Slide 2" class=""></button>
            <button type="button" data-bs-target="#myCarousel" data-bs-slide-to="2" aria-label="Slide 3" class="active" aria-current="true"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item">
                <img src="res/photo/placeholder_hor_1145.jpg" class="carousel-image w-100 h-100"/>
                <div class="container">
                    <div class="carousel-caption text-start">
                        <h1>Lorem Ipsum</h1>
                        <p class="opacity-75">Dolor Sit Amet</p>
                        <p><a class="btn btn-lg btn-primary" href="#">Albumy</a></p>
                    </div>
                </div>
            </div>
            <div class="carousel-item">
                <img src="res/photo/placeholder_hor_1113.jpg" class="carousel-image w-100 h-100"/>
                <div class="container">
                    <div class="carousel-caption">
                        <h1>Hej! Tu Karol :)</h1>
                        <p class="opacity-75">Zapraszam Cię do obejrzenia mojego portfolio!</p>
                        <p><a class="btn btn-lg btn-primary" href="#display-section">Albumy</a></p>
                    </div>
                </div>
            </div>
            <div class="carousel-item active">
                <img src="res/photo/placeholder_hor_0360.jpg" class="carousel-image w-100 h-100"/>
                <div class="container">
                    <div class="carousel-caption text-end">
                        <h1>Zainteresowany zdjęciami?</h1>
                        <p class="opacity-75">Skontaktuj się ze mną!</p>
                        <p><a class="btn btn-lg btn-primary" href="#contact-form">Kontakt</a></p>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#myCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#myCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <div class="container" id="display-section">
        <hr class="featurette-divider">

        @if(Model.Sections==null || Model.Sections.Count == 0)
        {
            <partial name="/Views/Shared/_NoContent.cshtml" />
            <hr class="featurette-divider">
        }
        else
        {
            int i = 0;
            @foreach(Section sect in Model.Sections){
                <div class="row featurette position-relative">
                    <a href="@Url.Action("Section", "Gallery", new {section=sect.UrlRef})" class="stretched-link"></a>
                    @if (i % 2 == 1)
                    {
                        <div class="col-md-5">
                            <img src="@sect.SectionCover.Path" class="bd-placeholder-img bd-placeholder-img-lg featurette-image img-fluid mx-auto" width="400" height="500" role="img" aria-label="Section Cover" preserveAspectRatio="xMidYMid slice" focusable="false"/>
                        </div>
                    }
                    <div class="col-md-7">
                        <h2 class="featurette-heading fw-normal lh-1">@sect.SectionName</h2>
                        <p class="lead">
                            @sect.SectionDescription
                        </p>
                    </div>
                    @if (i % 2 == 0)
                    {
                        <div class="col-md-5">
                            <img src="@sect.SectionCover.Path" class="bd-placeholder-img bd-placeholder-img-lg featurette-image img-fluid mx-auto" role="img" aria-label="Section Cover" preserveAspectRatio="xMidYMid slice" focusable="false" width="400" height="500" />
                        </div>
                    }
                </div>
                <hr class="featurette-divider">
                i++;
            }
        }
    </div>

    <div class="container">
        <partial name="/Views/Shared/_ContactForm.cshtml" />
        <hr class="featurette-divider">
    </div>
