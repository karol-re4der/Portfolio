@model SectionViewModel

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Model.Section.SectionName;
    string PageCover = Model.Section.SectionCover == null ? ImageUtility.GetPlaceholder(true) : Model.Section.SectionCover.Path;
}

<section class="p-0 text-center container bg-body-primary m-0 mw-100 w-100">
    <div class="row p-0 headerImage m-0 mw-100 w-100" style="background-image: url('@PageCover'); height:32rem;">
        <div class="col-lg-6 col-md-8 m-auto mh-100 overflow-hidden">
            <h1 class="text-light fw-light">@Model.Section.SectionName</h1>
            <p class="lead text-light overflow-hidden">@Model.Section.SectionDescription</p>
            <p>
                <a asp-area="User" asp-controller="Home" asp-action="Index" class="btn btn-primary my-2">Wróć</a>
                <a asp-area="User" asp-controller="Home" asp-action="Contact" class="btn btn-secondary my-2">Skontaktuj się ze mną!</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-area="Admin" asp-controller="Admin" asp-action="UpsertSection" asp-route-albumId="@Model.Section.Id" class="btn btn-secondary my-2">Edytuj</a>
                }
            </p>
        </div>
    </div>
</section>

<div class="album py-0 bg-body-primary">
    <div class="container">
        <hr class="featurette-divider">

            @if(Model.Section==null || Model.Section.Albums==null || Model.Section.Albums.Count()==0)
            {
                <partial name="/Views/Shared/_NoContent.cshtml" />
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
                    @foreach(Album album in Model.Section.Albums)
                    {
                        <div class="col">
                            <div>
                                <div class="card shadow-sm hasOverlay">
                                    <a href="@Url.Action("Album", "Gallery", new {album=album.UrlRef})">
                                        <div class="ratio" style="--bs-aspect-ratio: 125%;">
                                            @{
                                                string Cover = album.CoverPhoto == null ? ImageUtility.GetPlaceholder(true) : album.CoverPhoto.Path;
                                            }
                                            <img style="object-fit:cover;" class="bd-placeholder-img card-img-top" src="@Cover" role="img" aria-label="Placeholder: Thumbnail" preserveAspectRatio="xMidYMid slice" focusable="false" />
                                        </div>

                                        <div class="card-body d-flex">
                                            <strong class="card-text me-auto">
                                                @album.AlbumName
                                            </strong>
                                            <small class="text-body-secondary">
                                                @album.AlbumDateTime.ToString("MMM yyyy")
                                            </small>
                                        </div>
                                    </a>

                                    @if (SignInManager.IsSignedIn(User))
                                    {
                                        <div class="position-absolute w-100 top-0 bg-black overlay">
                                            <div class="btn-group w-100 m-100">
                                                <a asp-area="Admin" asp-controller="Admin" asp-action="UpsertAlbum" asp-route-albumId="@album.Id" class="btn btn-outline-primary">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <a asp-area="Admin" asp-controller="Admin" asp-action="UpsertPhotos" asp-route-albumId="@album.Id" asp-route-returnRef="@Model.Section.UrlRef" class="btn btn-outline-primary">
                                                    <i class="bi bi-plus-square"></i>
                                                </a>
                                                <a asp-area="Admin" asp-controller="Admin" asp-action="RemoveAlbum" asp-route-albumId="@album.Id" asp-route-returnRef="@Model.Section.UrlRef" class="btn btn-outline-primary requireConfirmation">
                                                    <i class="bi bi-trash3-fill"></i>
                                                </a>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        <hr class="featurette-divider">
    </div>
</div>