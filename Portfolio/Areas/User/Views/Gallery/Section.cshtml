@model SectionViewModel

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = Model.Section.SectionName;
}

<section class="p-0 text-center container bg-body-primary m-0 mw-100 w-100">
    <div class="row p-0 headerImage m-0 mw-100 w-100" style="background-image: url('@Model.Section.SectionCover.Path'); height:32rem;">
        <div class="col-lg-6 col-md-8 m-auto mh-100 overflow-hidden">
            <h1 class="fw-light">@Model.Section.SectionName</h1>
            <p class="lead text-body-secondary overflow-hidden">@Model.Section.SectionDescription</p>
            <p>
                <a href="#" class="btn btn-primary my-2">Wróć</a>
                <a asp-area="User" asp-controller="Home" asp-action="Contact" class="btn btn-secondary my-2">Skontaktuj się ze mną!</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-area="Admin" asp-controller="Admin" asp-action="UpsertSection" asp-route-albumId="@Model.Section.Id" class="btn btn-secondary my-2">Edytuj</a>
                }
            </p>
        </div>
    </div>
</section>

<div class="album py-0 bg-body-primary">
    <div class="container">
        <hr class="featurette-divider">

            @if(Model.Section==null || Model.Section.Albums==null || Model.Section.Albums.Count()==0)
            {
                <partial name="/Views/Shared/_NoContent.cshtml" />
            }
            else
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
                @foreach(Album album in Model.Section.Albums)
                {
                    <div class="col">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="btn-group text-center">
                                <a asp-area="Admin" asp-controller="Admin" asp-action="UpsertAlbum" asp-route-albumId="@album.Id" class="btn btn-outline-primary p-1"><i class="bi bi-pencil-square"></i></a>
                                <a asp-area="User" asp-controller="Home" asp-action="Index" class="btn btn-outline-primary p-1"><i class="bi bi-trash3-fill"></i></a>
                            </div>
                        }
                        <div class="card shadow-sm">
                            <div class="ratio" style="--bs-aspect-ratio: 125%;">
                                @{
                                    string Cover = album.CoverPhoto == null ? ImageUtility.GetPlaceholder(true) : album.CoverPhoto.Path;
                                }
                                <img style="object-fit:cover;" class="bd-placeholder-img card-img-top" src="@Cover" role="img" aria-label="Placeholder: Thumbnail" preserveAspectRatio="xMidYMid slice" focusable="false" />
                            </div>
                            <div class="card-body d-flex">
                                <strong class="card-text me-auto">
                                    @album.AlbumName
                                </strong>
                                <small class="text-body-secondary">
                                    @album.AlbumDateTime.ToString("MMM yyyy")
                                </small>
                                <a href="@Url.Action("Album", "Gallery", new {album=album.UrlRef})" class="stretched-link"></a>
                            </div>
                        </div>
                    </div>
                }
                </div>
            }

        <hr class="featurette-divider">
    </div>
</div>